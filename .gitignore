# =============================================================================
# forge — Helm charts + ArgoCD values for mgmt-forge and OKD
# =============================================================================

# -----------------------------------------------------------------------------
# Helm
# -----------------------------------------------------------------------------
# Downloaded subchart tarballs — regenerated by `helm dependency update`.
# Never commit these; dep versions are pinned in Chart.yaml.
**/charts/*.tgz
**/charts/*.tar.gz

# Chart.lock is generated by `helm dependency update` to cache resolved deps.
# We pin exact versions in Chart.yaml already; lock is redundant and drifts.
**/Chart.lock

# Local helm state
.helm/

# -----------------------------------------------------------------------------
# Secrets & credentials
# -----------------------------------------------------------------------------
# All real secrets live in Vault and are materialized via ExternalSecret CRs.
# If a values-secret.yaml ever slips in by mistake, this catches it.
values-secret.yaml
values-secrets.yaml
**/*-secret.yaml.dec
*.decrypted
*.pem
*.key
!**/templates/*.yaml
id_rsa
id_rsa.pub
kubeconfig
**/kubeconfig

# -----------------------------------------------------------------------------
# Ansible (vault/playbooks uses Ansible)
# -----------------------------------------------------------------------------
*.retry
.ansible/

# -----------------------------------------------------------------------------
# Claude Code
# -----------------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------------
# OS & editor
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*~
*.swp
*.swo
.vscode/
.idea/
*.code-workspace

# -----------------------------------------------------------------------------
# Logs & temp
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
